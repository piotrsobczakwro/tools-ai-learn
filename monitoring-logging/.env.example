# Monitoring & Logging — Environment Variables
# Copy to .env and fill in your values before running podman-compose up
# DO NOT commit .env to version control

# Kibana
# Generate: openssl rand -hex 32
KIBANA_ENCRYPTION_KEY=replace_with_random_32_byte_hex_string

# Graylog
# Generate: pwgen -N 1 -s 96
GRAYLOG_PASSWORD_SECRET=replace_with_strong_96_char_secret

# Generate: echo -n "yourpassword" | sha256sum | cut -d " " -f 1
GRAYLOG_ROOT_PASSWORD_SHA2=replace_with_sha256_of_your_admin_password
