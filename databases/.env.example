# Databases — Environment Variables
# Copy to .env and fill in your values before running podman-compose up
# DO NOT commit .env to version control

# MySQL
MYSQL_ROOT_PASSWORD=replace_with_strong_password
MYSQL_DATABASE=appdb
MYSQL_USER=appuser
MYSQL_PASSWORD=replace_with_strong_password

# PostgreSQL
POSTGRES_USER=pguser
POSTGRES_PASSWORD=replace_with_strong_password
POSTGRES_DB=appdb

# Percona XtraDB Cluster
PXC_ROOT_PASSWORD=replace_with_strong_password
PXC_XTRABACKUP_PASSWORD=replace_with_strong_password
PXC_DATABASE=pxcdb
PXC_USER=pxcuser
PXC_PASSWORD=replace_with_strong_password
